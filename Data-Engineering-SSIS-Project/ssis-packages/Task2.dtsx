    <DTS:Executable
      DTS:refId="Package\Execute SQL Task - Initialize Metadata Table that has the date for the last ETL run"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{27D9DB74-6AAC-4AB6-9081-4545F668732D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task - Initialize Metadata Table that has the date for the last ETL run"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1ECB7B23-43F7-4247-91BF-0539F23668CD}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'ETL_Metadata')&#xA;BEGIN&#xA;    CREATE TABLE ETL_Metadata (&#xA;        ProcessName VARCHAR(50),&#xA;        LastLoadDate DATE&#xA;    );&#xA;&#xA;    INSERT INTO ETL_Metadata&#xA;    VALUES ('Campaign_Load', '1900-01-01');&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Execute SQL Task - Update LastLoadDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{26DD43E0-6B08-4519-BA7D-190291B03742}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task - Update LastLoadDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1ECB7B23-43F7-4247-91BF-0539F23668CD}"
          SQLTask:SqlStatementSource="UPDATE ETL_Metadata&#xA;SET LastLoadDate = CAST(GETDATE() AS DATE)&#xA;WHERE ProcessName = 'Campaign_Load';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
