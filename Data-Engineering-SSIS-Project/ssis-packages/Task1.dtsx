                    <arrayElement
                      dataType="System.String"><![CDATA[using System;
using System.Net;
using System.Text;
using System.Globalization;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void CreateNewOutputRows()
    {
        try
        {
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;

            string url = "https://69be08c917c3d7d977910f4e.mockapi.io/us_air_quality/air_monitoring";

            WebClient wc = new WebClient();
            wc.Encoding = Encoding.UTF8;

            string json = wc.DownloadString(url);

            string[] records = json.Split(new string[] { "{" }, StringSplitOptions.RemoveEmptyEntries);

            foreach (string r in records)
            {
                if (r.Contains("id"))
                {
                    Output0Buffer.AddRow();

                    // ===== STRING FIELDS =====
                    string id = Extract(r, "id");
                    string city = Extract(r, "location");
                    string timestamp = Extract(r, "timestamp");

                    // sensor_id
                    Output0Buffer.sensorid = string.IsNullOrWhiteSpace(id) ? "UNKNOWN" : id;

                    // city
                    Output0Buffer.city = string.IsNullOrWhiteSpace(city) ? "UNKNOWN" : city;

                    // timestamp (remove T)
                    if (string.IsNullOrWhiteSpace(timestamp))
                        timestamp = "1900-01-01 00:00:00";
                    else
                        timestamp = timestamp.Replace("T", " ");

                    Output0Buffer.timestamp = timestamp;

                    // ===== NUMERIC FIELDS =====
                    double pm25 = 0;
                    double pm10 = 0;

                    string p1 = Extract(r, "pm25").Trim();
                    string p2 = Extract(r, "pm10").Trim();

                    if (!double.TryParse(p1, NumberStyles.Any, CultureInfo.InvariantCulture, out pm25))
                        pm25 = 0;

                    if (!double.TryParse(p2, NumberStyles.Any, CultureInfo.InvariantCulture, out pm10))
                        pm10 = 0;

                    // handle negative OR zero
                    if (pm25 <= 0) pm25 = 0;
                    if (pm10 <= 0) pm10 = 0;

                    Output0Buffer.pm25 = pm25;
                    Output0Buffer.pm10 = pm10;

                    // source
                    Output0Buffer.source = "API";
                }
            }
        }
        catch (Exception ex)
        {
            bool cancel = false;
            ComponentMetaData.FireError(0, "API ERROR", ex.Message, "", 0, out cancel);
        }
    }

    // ===== Helper function =====
    private string Extract(string text, string key)
    {
        try
        {
            int i = text.IndexOf("\"" + key + "\"");
            if (i == -1) return "";

            i = text.IndexOf(":", i) + 1;

            // skip spaces
            while (i < text.Length && (text[i] == ' ')) i++;

            // if string value
            if (i < text.Length && text[i] == '"')
            {
                i++;
                int j = text.IndexOf("\"", i);
                return text.Substring(i, j - i).Trim();
            }
            else
            {
                int j = i;
                while (j < text.Length && text[j] != ',' && text[j] != '}')
                    j++;

                return text.Substring(i, j - i).Trim();
            }
        }
        catch
        {
            return "";
        }
    }
}]]></arrayElement>
